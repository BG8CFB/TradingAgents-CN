# TradingAgents-CN 部署配置模板（精简版）
# ════════════════════════════════════════════════════════════
# 使用方法：
#   1. 将此文件和 docker-compose.hub.nginx.yml 下载到部署目录
#   2. cp deploy/.env.example .env（或直接在部署目录创建 .env）
#   3. 修改下面的密码与 Token
#   4. 启动: docker compose -f docker-compose.hub.nginx.yml up -d
#
# 所有变量都有合理默认值，不创建 .env 也能启动。
# 此文件仅列出部署时最常需要自定义的变量。
# ════════════════════════════════════════════════════════════

# ── 版本（默认拉取 latest，可固定到指定 tag） ──
TA_VERSION=latest

# ── 对外端口（Nginx 反向代理监听） ──
NGINX_PORT=8080

# ── 数据库密码（首次部署后请勿修改，否则数据无法连接） ──
MONGO_ROOT_USERNAME=admin
MONGODB_PASSWORD=tradingagents123
REDIS_PASSWORD=tradingagents123

# ── 安全密钥（留空则首次启动自动生成并持久化到数据库） ──
# 生产环境建议显式设置，生成方式：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
CSRF_SECRET=

# ── 首次管理员账号（仅首次启动用，之后从数据库读取） ──
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@tradingagents.cn
INITIAL_ADMIN_PASSWORD=admin123

# ── 数据源 API Token（可选，也可通过 Web UI 配置） ──
TUSHARE_TOKEN=
FINNHUB_API_KEY=
