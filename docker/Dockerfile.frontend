# Frontend Dockerfile for Vue 3 + Vite app (TradingAgents-CN v1.0.0-preview)
# 前后端分离架构 - 前端服务

# 构建阶段：使用Node.js 22.x（与项目开发环境一致）
# 使用 1ms.run 镜像源加速下载
FROM docker.1ms.run/node:22-alpine AS build

ENV NODE_ENV=production
WORKDIR /app/frontend

# 复制package.json、package-lock.json和npmrc配置
COPY frontend/package.json frontend/package-lock.json ./

# 配置npm国内镜像源
RUN npm config set registry https://registry.npmmirror.com

# 安装依赖（使用package-lock.json确保版本一致）
# 增加网络超时时间到5分钟，适应跨平台构建的网络延迟
RUN npm ci --include=dev --timeout=300000

# 复制前端源代码
COPY frontend/. ./

# 构建生产版本（使用 vite build 跳过类型检查，避免类型错误导致构建失败）
RUN npx vite build

# 运行阶段：使用Nginx提供静态文件服务
# 使用 1ms.run 镜像源加速下载
FROM docker.1ms.run/nginx:alpine AS runtime

# 设置时区环境变量
ENV TZ=Asia/Shanghai

# 安装时区数据并配置
RUN apk add --no-cache tzdata && \
    ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && \
    echo $TZ > /etc/timezone

WORKDIR /usr/share/nginx/html

# 从构建阶段复制构建产物
COPY --from=build /app/frontend/dist .

# 复制Nginx配置（支持SPA路由）
COPY docker/nginx/frontend.conf /etc/nginx/conf.d/default.conf

# 暴露端口80
EXPOSE 80

# 启动Nginx
CMD ["nginx", "-g", "daemon off;"]
