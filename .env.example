# TradingAgents-CN 配置模板（项目级参考）
# ════════════════════════════════════════════════════════════
# 用途：
#   - 本地开发：复制为 .env，按需修改
#   - Docker 部署：参考 deploy/.env.example（更精简）
#   - LLM API Key：请通过 Web UI 配置（不在此文件）
#
# 配置加载优先级（高 → 低）：
#   1. 部署目录 .env（用户显式配置）
#   2. docker-compose.yml 的 ${VAR:-default}（内联默认值）
#   3. 应用代码默认值
# ════════════════════════════════════════════════════════════

# ═══ Docker Compose 层变量（仅 compose 读取，应用代码不直接使用） ═══
# 这些变量被 docker-compose.hub.nginx.yml / docker-compose.dev.yml 引用，
# 用于控制容器编排行为（端口、镜像版本、Mongo 初始化账号）
TA_VERSION=latest                       # 镜像 tag（hub.nginx 部署用）
NGINX_PORT=8080                         # 对外端口（hub.nginx 部署用）
MONGO_ROOT_USERNAME=admin               # Mongo 容器初始化的 root 账号（同时映射到 MONGODB_USERNAME）

# ═══ 基础设施（必需） ═══
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=tradingagents123
MONGODB_DATABASE=tradingagents
MONGODB_AUTH_SOURCE=admin

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=tradingagents123
REDIS_DB=0

# ═══ MongoDB 连接池 ═══
MONGO_MAX_CONNECTIONS=100
MONGO_MIN_CONNECTIONS=10
MONGO_CONNECT_TIMEOUT_MS=30000
MONGO_SOCKET_TIMEOUT_MS=60000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
REDIS_MAX_CONNECTIONS=20
REDIS_RETRY_ON_TIMEOUT=true

# ═══ 安全密钥（留空则首次启动自动生成并持久化到 DB） ═══
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
CSRF_SECRET=
BCRYPT_ROUNDS=12

# ═══ 首次管理员（仅首次启动用，之后从 DB 读取） ═══
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@tradingagents.cn
INITIAL_ADMIN_PASSWORD=admin123

# ═══ Web 服务 ═══
DEBUG=false
HOST=0.0.0.0
PORT=8000
NGINX_PORT=8080
TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai

# ═══ CORS 与上传 ═══
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8080"]
ALLOWED_HOSTS=["*"]
MAX_UPLOAD_SIZE=10485760

# ═══ 数据源 Token（可选，也可在 Web UI 配置） ═══
# Tushare 三市场独立 Token —— 凭据/积分完全隔离，失败互不传染
# 若市场专属 Token 留空，会回退到旧的 TUSHARE_TOKEN（保持向后兼容）
TUSHARE_CN_TOKEN=
TUSHARE_HK_TOKEN=
TUSHARE_US_TOKEN=
# 旧字段：保留作为三市场专属 Token 未配置时的兜底
TUSHARE_TOKEN=
TUSHARE_ENABLED=true
TUSHARE_TIER=standard
TUSHARE_RATE_LIMIT_SAFETY_MARGIN=0.8
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ═══ 实时行情入库（推荐默认值） ═══
QUOTES_INGEST_ENABLED=true
QUOTES_INGEST_INTERVAL_SECONDS=360
QUOTES_ROTATION_ENABLED=true
QUOTES_TUSHARE_HOURLY_LIMIT=2
QUOTES_AUTO_DETECT_TUSHARE_PERMISSION=true
QUOTES_BACKFILL_ON_STARTUP=true
QUOTES_BACKFILL_ON_OFFHOURS=true

# ═══ 数据同步调度总开关 ═══
TUSHARE_UNIFIED_ENABLED=true
AKSHARE_UNIFIED_ENABLED=true
BAOSTOCK_UNIFIED_ENABLED=true
HK_UNIFIED_ENABLED=false
US_UNIFIED_ENABLED=false

# ═══ 并发与队列 ═══
DEFAULT_USER_CONCURRENT_LIMIT=3
GLOBAL_CONCURRENT_LIMIT=50
DEFAULT_DAILY_QUOTA=1000
QUEUE_MAX_SIZE=10000
QUEUE_MAX_RETRIES=3
QUEUE_VISIBILITY_TIMEOUT=300
WORKER_HEARTBEAT_INTERVAL=30

# ═══ 缓存与会话 ═══
CACHE_TTL=3600
SCREENING_CACHE_TTL=1800
SESSION_EXPIRE_HOURS=24

# ═══ 限流 ═══
RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100

# ═══ 日志 ═══
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ═══ 分析师数据范围 ═══
# 默认60天：可覆盖MA60等所有常用技术指标（MA5/10/20/60, MACD, RSI, BOLL）
MARKET_ANALYST_LOOKBACK_DAYS=60

# ═══ 股票基础信息同步调度 ═══
SYNC_STOCK_BASICS_ENABLED=true
SYNC_STOCK_BASICS_TIME=06:30

# ═══ 异步线程池与 WebSocket 连接上限 ═══
# 数据同步等 CPU-bound 任务桥接到线程池的大小
ASYNC_THREAD_POOL_SIZE=16
# 分析任务专用线程池大小
ANALYSIS_THREAD_POOL_SIZE=3
# 单个分析任务的 WebSocket 最大连接数
WEBSOCKET_MAX_CONNECTIONS_PER_TASK=5
# 全局 WebSocket 最大连接数
WEBSOCKET_MAX_TOTAL_CONNECTIONS=1000

# ═══ 数据同步并发数（按市场） ═══
# 总并发数（跨市场共享）
DATA_SYNC_CONCURRENCY=8
# 各市场独立并发数
CN_SYNC_CONCURRENCY=8
HK_SYNC_CONCURRENCY=8
US_SYNC_CONCURRENCY=8

# ═══ 代理（访问国外服务时配置） ═══
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1,eastmoney.com,api.tushare.pro,baostock.com

# ═══ Skill 系统（技能包：可分发的分析能力扩展） ═══
# 首次加载 skill 时自动 pip install 声明的依赖（仅在 Docker 容器内执行）
# 关闭后，skill 声明的依赖只检查不安装，需手动通过 API 或前端触发安装
SKILL_AUTO_INSTALL=true
# 允许自动安装的 PyPI 包名白名单（逗号分隔，空表示不限制）
# 例：SKILL_ALLOWED_PACKAGES=mplfinance,pandas,ta-lib
SKILL_ALLOWED_PACKAGES=
# 单次 skill 依赖 pip install 的超时时间（秒，范围 30-1800）
SKILL_INSTALL_TIMEOUT=300
# 中心化 skill 注册表地址（预留，本期未实现；空表示不启用）
SKILL_REGISTRY_URL=
# 允许从 Git URL 安装 skill 的可信主机白名单（逗号分隔）
SKILL_GIT_TRUSTED_HOSTS=github.com,gitee.com
