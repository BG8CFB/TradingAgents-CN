# TradingAgents-CN 系统配置
#
# LLM API Key 请通过 Web UI 配置：登录后 → 设置 → 配置管理 → 厂家管理
# 数据源 Token 也可通过 Web UI 配置，但 .env 中的值会作为兜底
#
# 配置级别说明：
#   [REQUIRED]    - 系统启动必需
#   [RECOMMENDED] - 推荐配置，缺少会影响功能
#   [OPTIONAL]    - 可选配置

# ==================== 必需配置（系统启动必需） ====================

# [REQUIRED] MongoDB 数据库连接
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=tradingagents123
MONGODB_DATABASE=tradingagents
MONGODB_AUTH_SOURCE=admin

# [REQUIRED] Redis 缓存连接
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=tradingagents123
REDIS_DB=0

# ==================== 推荐配置 ====================

# [RECOMMENDED] 数据源 API Token（也可在 Web UI 配置）
# Tushare API Token（专业A股数据，https://tushare.pro/）
# TUSHARE_TOKEN=your_tushare_token_here
# TUSHARE_ENABLED=true

# FinnHub API Key（美股数据，https://finnhub.io/）
# FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API Key（美股数据）
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ==================== 可选配置 ====================

# [OPTIONAL] Docker 标识（容器内自动设置，本地运行留空）
# DOCKER_CONTAINER=true

# [OPTIONAL] 首次启动管理员密码
# INITIAL_ADMIN_PASSWORD=admin123

# [OPTIONAL] 代理配置（访问国外服务时使用）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1,eastmoney.com,api.tushare.pro,baostock.com

# [OPTIONAL] 运行时配置
RUNTIME_BASE_DIR=runtime
LOG_LEVEL=INFO
